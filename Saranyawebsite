<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SARANYA LAB — Advanced Diagnostic Sciences</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0a0e14;
    --paper: #f4f1eb;
    --cream: #ede9e0;
    --teal: #0d6e6e;
    --teal-light: #14a0a0;
    --teal-pale: #d4eeee;
    --red: #c23b22;
    --gold: #b8943f;
    --mid: #6b7280;
    --light-border: #d8d4ca;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: 'Instrument Sans', sans-serif;
    overflow-x: hidden;
    cursor: none;
  }

  /* Custom cursor */
  .cursor {
    position: fixed;
    width: 10px; height: 10px;
    background: var(--teal);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    transition: transform 0.1s, width 0.2s, height 0.2s, background 0.2s;
    mix-blend-mode: multiply;
  }
  .cursor-ring {
    position: fixed;
    width: 36px; height: 36px;
    border: 1.5px solid var(--teal);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%,-50%);
    transition: transform 0.18s ease, width 0.2s, height 0.2s;
    opacity: 0.5;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.4rem 4rem;
    background: rgba(244,241,235,0.85);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--light-border);
  }
  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
  }
  .nav-logo span { color: var(--teal); }
  .nav-links {
    display: flex; gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--teal); }
  .nav-cta {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: var(--teal);
    color: white;
    border: none;
    padding: 0.7rem 1.6rem;
    cursor: none;
    transition: background 0.2s, transform 0.15s;
  }
  .nav-cta:hover { background: var(--teal-light); transform: translateY(-1px); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-left {
    padding: 7rem 4rem 5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .hero-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.8rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .hero-tag::before {
    content: '';
    display: inline-block;
    width: 28px; height: 1px;
    background: var(--teal);
  }
  .hero-headline {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(3.2rem, 5.5vw, 5.8rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 2rem;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--teal);
  }
  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--mid);
    max-width: 420px;
    margin-bottom: 3rem;
  }
  .hero-actions { display: flex; gap: 1rem; align-items: center; }
  .btn-primary {
    background: var(--ink);
    color: var(--paper);
    padding: 1rem 2.2rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: none;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--teal); transform: translateY(-2px); }
  .btn-secondary {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 1rem 1.5rem;
    border: 1px solid var(--light-border);
    cursor: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-secondary:hover { border-color: var(--teal); color: var(--teal); }

  .hero-stats {
    margin-top: 4rem;
    display: flex; gap: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--light-border);
  }
  .stat-val {
    font-family: 'DM Serif Display', serif;
    font-size: 2.4rem;
    color: var(--ink);
    letter-spacing: -0.03em;
  }
  .stat-val span { color: var(--teal); }
  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mid);
    margin-top: 0.2rem;
  }

  .hero-right {
    background: var(--ink);
    position: relative;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-visual {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }
  /* Animated DNA / molecule graphic */
  .molecule-svg {
    width: 70%; opacity: 0.12;
    animation: rotateSlow 24s linear infinite;
  }
  @keyframes rotateSlow { to { transform: rotate(360deg); } }

  .hero-card {
    position: relative; z-index: 3;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    padding: 2.5rem;
    width: min(340px, 85%);
    animation: fadeUp 1s ease both 0.4s;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .card-chip {
    display: inline-block;
    background: var(--teal);
    color: white;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 0.75rem;
    margin-bottom: 1.4rem;
  }
  .card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    color: white;
    margin-bottom: 0.6rem;
  }
  .card-sub {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.45);
    margin-bottom: 1.6rem;
    line-height: 1.6;
  }
  .progress-list { display: flex; flex-direction: column; gap: 1rem; }
  .prog-item {}
  .prog-label {
    display: flex; justify-content: space-between;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.4rem;
  }
  .prog-bar { height: 3px; background: rgba(255,255,255,0.08); position: relative; }
  .prog-fill {
    position: absolute; top: 0; left: 0; bottom: 0;
    background: var(--teal-light);
    animation: fillBar 1.6s ease both;
  }
  @keyframes fillBar { from { width: 0 !important; } }

  /* ─── TICKER ─── */
  .ticker {
    background: var(--teal);
    color: white;
    overflow: hidden;
    padding: 0.75rem 0;
    white-space: nowrap;
  }
  .ticker-inner {
    display: inline-flex; gap: 5rem;
    animation: tickerScroll 28s linear infinite;
  }
  @keyframes tickerScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .ticker-item {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 1rem;
  }
  .ticker-dot { width: 5px; height: 5px; background: rgba(255,255,255,0.4); border-radius: 50%; }

  /* ─── SERVICES ─── */
  .section { padding: 7rem 4rem; }
  .section-header { margin-bottom: 4rem; }
  .section-tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.8rem;
  }
  .section-tag::before { content: ''; width: 24px; height: 1px; background: var(--teal); display: inline-block; }
  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 520px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: var(--light-border);
    border: 1.5px solid var(--light-border);
  }
  .service-card {
    background: var(--paper);
    padding: 2.8rem 2.4rem;
    transition: background 0.25s;
    cursor: none;
    position: relative;
    overflow: hidden;
  }
  .service-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--teal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .service-card:hover { background: var(--cream); }
  .service-card:hover::after { transform: scaleX(1); }
  .service-num {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    color: var(--teal);
    margin-bottom: 1.8rem;
  }
  .service-icon {
    width: 40px; height: 40px;
    margin-bottom: 1.4rem;
    stroke: var(--ink);
    stroke-width: 1.5;
    fill: none;
  }
  .service-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.35rem;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }
  .service-desc {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--mid);
    margin-bottom: 1.8rem;
  }
  .service-link {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--teal);
    text-decoration: none;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .service-link:hover { gap: 0.9rem; }
  .service-link::after { content: '→'; transition: margin 0.2s; }

  /* ─── PROCESS ─── */
  .process-section {
    padding: 7rem 4rem;
    background: var(--ink);
    color: white;
  }
  .process-section .section-tag { color: var(--teal-light); }
  .process-section .section-tag::before { background: var(--teal-light); }
  .process-section .section-title { color: white; max-width: 480px; }
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 4rem;
    background: rgba(255,255,255,0.06);
  }
  .step {
    background: transparent;
    padding: 2.5rem 2rem;
    position: relative;
    border-right: 1px solid rgba(255,255,255,0.07);
    cursor: none;
    transition: background 0.25s;
  }
  .step:last-child { border-right: none; }
  .step:hover { background: rgba(13,110,110,0.15); }
  .step-num {
    font-family: 'DM Serif Display', serif;
    font-size: 4rem;
    color: rgba(255,255,255,0.06);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .step-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    color: white;
    margin-bottom: 0.7rem;
  }
  .step-desc {
    font-size: 0.83rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
  }
  .step-time {
    margin-top: 1.5rem;
    display: inline-block;
    background: rgba(13,110,110,0.3);
    color: var(--teal-light);
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
  }

  /* ─── ABOUT SPLIT ─── */
  .about-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }
  .about-left {
    padding: 7rem 5rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .about-right {
    background: var(--cream);
    padding: 5rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
    gap: 2rem;
    border-left: 1.5px solid var(--light-border);
  }
  .about-body {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--mid);
    margin-top: 2rem;
    max-width: 440px;
  }
  .cert-item {
    display: flex; gap: 1.2rem; align-items: flex-start;
    padding: 1.4rem;
    background: white;
    border: 1px solid var(--light-border);
    transition: border-color 0.2s;
    cursor: none;
  }
  .cert-item:hover { border-color: var(--teal); }
  .cert-icon-wrap {
    width: 38px; height: 38px;
    flex-shrink: 0;
    background: var(--teal-pale);
    display: flex; align-items: center; justify-content: center;
  }
  .cert-icon { width: 20px; height: 20px; stroke: var(--teal); fill: none; stroke-width: 1.8; }
  .cert-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }
  .cert-desc { font-size: 0.8rem; color: var(--mid); }

  /* ─── TESTS ─── */
  .tests-section { padding: 7rem 4rem; background: var(--cream); }
  .tests-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    margin-top: 3.5rem;
  }
  .test-tile {
    background: white;
    border: 1px solid var(--light-border);
    padding: 1.8rem 1.5rem;
    cursor: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .test-tile:hover {
    transform: translateY(-4px);
    border-color: var(--teal);
    box-shadow: 0 12px 36px rgba(0,0,0,0.08);
  }
  .test-badge {
    position: absolute; top: 1rem; right: 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
  }
  .badge-fast { background: #fef3c7; color: #92400e; }
  .badge-new { background: var(--teal-pale); color: var(--teal); }
  .test-icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }
  .test-name {
    font-family: 'DM Serif Display', serif;
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }
  .test-turnaround {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--mid);
    text-transform: uppercase;
    margin-top: 0.8rem;
  }

  /* ─── TESTIMONIAL ─── */
  .testimonial-section {
    padding: 7rem 4rem;
    background: var(--teal);
    position: relative;
    overflow: hidden;
  }
  .testimonial-section::before {
    content: '"';
    position: absolute;
    top: -2rem; left: 2rem;
    font-family: 'DM Serif Display', serif;
    font-size: 20rem;
    color: rgba(255,255,255,0.05);
    line-height: 1;
  }
  .testimonials-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 3.5rem;
  }
  .testimonial-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 2.4rem;
  }
  .quote-text {
    font-family: 'DM Serif Display', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: white;
    line-height: 1.65;
    margin-bottom: 1.8rem;
  }
  .reviewer {
    display: flex; align-items: center; gap: 0.9rem;
  }
  .reviewer-avatar {
    width: 40px; height: 40px;
    background: rgba(255,255,255,0.2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'DM Serif Display', serif;
    font-size: 1rem;
    color: white;
  }
  .reviewer-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: white;
  }
  .reviewer-role {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-top: 0.1rem;
  }
  .test-stars { color: rgba(255,255,255,0.6); margin-bottom: 1rem; font-size: 0.85rem; }

  .testimonial-section .section-tag { color: rgba(255,255,255,0.6); }
  .testimonial-section .section-tag::before { background: rgba(255,255,255,0.4); }
  .testimonial-section .section-title { color: white; }

  /* ─── BOOK ─── */
  .book-section {
    display: grid; grid-template-columns: 1fr 1fr;
    background: var(--cream);
    border-top: 1.5px solid var(--light-border);
  }
  .book-left {
    padding: 7rem 5rem;
    border-right: 1px solid var(--light-border);
  }
  .book-right {
    padding: 5rem 4rem;
    background: var(--ink);
  }
  .form-group { margin-bottom: 1.5rem; }
  .form-label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.5rem;
  }
  .form-input {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.9rem 1rem;
    color: white;
    font-family: 'Instrument Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    cursor: none;
    transition: border-color 0.2s;
  }
  .form-input:focus { border-color: var(--teal-light); }
  .form-input::placeholder { color: rgba(255,255,255,0.2); }
  select.form-input option { background: var(--ink); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-submit {
    width: 100%;
    background: var(--teal);
    color: white;
    border: none;
    padding: 1.1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: none;
    transition: background 0.2s, transform 0.15s;
    margin-top: 0.5rem;
  }
  .form-submit:hover { background: var(--teal-light); transform: translateY(-1px); }
  .book-left .section-title { max-width: 400px; }
  .book-body {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--mid);
    margin-top: 1.8rem;
    margin-bottom: 3rem;
    max-width: 400px;
  }
  .contact-list { display: flex; flex-direction: column; gap: 1.2rem; }
  .contact-item {
    display: flex; align-items: center; gap: 1rem;
    font-size: 0.9rem;
    color: var(--mid);
  }
  .contact-item-icon {
    width: 36px; height: 36px;
    background: var(--teal-pale);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .contact-item-icon svg { width: 16px; height: 16px; stroke: var(--teal); fill: none; stroke-width: 2; }

  /* ─── FOOTER ─── */
  footer {
    background: var(--ink);
    color: rgba(255,255,255,0.4);
    padding: 3rem 4rem;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .footer-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.3rem;
    color: white;
    text-decoration: none;
  }
  .footer-logo span { color: var(--teal-light); }
  .footer-copy {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
  }
  .footer-links {
    display: flex; gap: 2rem;
    list-style: none;
  }
  .footer-links a {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--teal-light); }

  /* ─── ANIMATIONS on scroll ─── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: none;
  }
</style>
</head>
<body>

