<script>
  // Cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cursor.style.left=mx+'px';cursor.style.top=my+'px';});
  (function animRing(){rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(animRing);})();
  document.querySelectorAll('a,button,.service-card,.step,.cert-item,.test-tile').forEach(el=>{
    el.addEventListener('mouseenter',()=>{cursor.style.width='18px';cursor.style.height='18px';ring.style.width='54px';ring.style.height='54px';});
    el.addEventListener('mouseleave',()=>{cursor.style.width='10px';cursor.style.height='10px';ring.style.width='36px';ring.style.height='36px';});
  });

  // Ticker
  const items=['ISO 15189 Accredited','NABL Certified','24/7 Emergency Lab','800+ Physician Partners','Same-Day Results Available','Digital Report Delivery','Home Collection Service','Saranya Lab — Trusted Since 2004'];
  const doubled=[...items,...items];
  const ti=document.getElementById('ticker-inner');
  doubled.forEach(t=>{const d=document.createElement('div');d.className='ticker-item';d.innerHTML=`<span class="ticker-dot"></span>${t}`;ti.appendChild(d);});

  // Scroll reveal
  const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('revealed');});},{threshold:0.12});
  document.querySelectorAll('[data-reveal]').forEach(el=>obs.observe(el));
  // Auto-reveal hero items with stagger
  document.querySelectorAll('.hero [data-reveal]').forEach((el,i)=>{
    setTimeout(()=>el.classList.add('revealed'),200+i*150);
  });
</script>
